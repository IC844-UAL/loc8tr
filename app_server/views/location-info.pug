extends layout

block content
  .location-minimal
    .minimal-header.mb-4
      h1.minimal-title= location.name
      p.minimal-address.mb-2= location.address
      .minimal-rating
        - const stars = Math.round(location.rating || 0)
        each val in [1,2,3,4,5]
          if val <= stars
            i.fas.fa-star
          else
            i.far.fa-star
        span.ms-2.text-muted.small= `${location.rating || 0}/5`

    .row.g-3
      .col-12.col-lg-7
        .minimal-card
          h2.minimal-section-title Opening hours
          each time in location.openingTimes
            .minimal-row
              span.minimal-row-label= time.days
              if time.closed
                span.minimal-row-value Closed
              else
                span.minimal-row-value= `${time.opening} - ${time.closing}`

        .minimal-card.mt-3
          .d-flex.justify-content-between.align-items-center.mb-3
            h2.minimal-section-title.mb-0 Reviews
            a.btn.btn-sm.btn-outline-dark(href=`/location/${location._id}/review/new`) Add review
          if location.reviews && location.reviews.length
            each review in location.reviews
              .minimal-review
                .d-flex.justify-content-between.align-items-center
                  .minimal-rating
                    - const reviewStars = Math.round(review.rating || 0)
                    each val in [1,2,3,4,5]
                      if val <= reviewStars
                        i.fas.fa-star
                      else
                        i.far.fa-star
                  small.text-muted= new Date(review.createdOn).toLocaleDateString()
                p.minimal-review-author.mb-1= review.author
                p.mb-0= review.reviewText
          else
            p.text-muted.mb-0 There are no reviews yet.
      .col-12.col-lg-5
        .minimal-card
          h2.minimal-section-title Facilities
          if location.facilities && location.facilities.length
            .minimal-tags
              each facility in location.facilities
                span.minimal-tag= facility
          else
            p.text-muted.mb-0 No facilities listed.
